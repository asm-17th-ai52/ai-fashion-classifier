# Context Agent — 환경 변수 예시.
# 본 파일은 Context Agent 단독 개발/테스트 시 참조용이며, 실제 값은
# 리포지토리 루트의 .env 에 채워 넣는다 (루트 .env.example 와 통합).

# Tier-2 ReAct 실시간 웹 리서치 — Tavily Search API.
# https://app.tavily.com/ 에서 발급. (무료 티어 1,000 calls/month)
TAVILY_API_KEY=tvly-dev-...

# 아래 키는 Vision Agent에서 이미 사용 중. 루트 .env.example 에 정의되어 있다.
# 본 Agent는 Tier-2 extract_facts (LLM structured output) 에서 동일 키를 재사용한다.
# GOOGLE_API_KEY=...
